def main(files):
    animation_frames = []
    
    # File1の重心を保存
    mesh1 = load_mesh(files[0])
    adjust_z(mesh1)
    ref_centroid = np.array(mesh1.centroid)

    times = [10, 12, 14, 17, 20, 24]
    time_intervals = np.diff(times)
    total_time = np.sum(time_intervals)
    time_intervals_normalized = time_intervals / total_time

    total_frames = 1000  # アニメーションの総フレーム数を設定
    file_frames = np.round(time_intervals_normalized * total_frames).astype(int)

    for i in range(len(files) - 1):
        file1 = files[i]
        file2 = files[i + 1]

        mesh1 = load_mesh(file1)
        adjust_z(mesh1)
        align_centroids_xy_only(mesh1, mesh1, ref_centroid)  # File1の重心に合わせる

        mesh2 = load_mesh(file2)
        adjust_z(mesh2)
        align_centroids_xy_only(mesh2, mesh2, ref_centroid)  # File1の重心に合わせる

        origin = np.array(mesh1.centroid)
        origin[2] = 2

        rays = generate_rays(origin)
        rays /= np.linalg.norm(rays, axis=1)[:, np.newaxis]

        intersections1, index_ray1, intersections2, index_ray2 = find_intersections(mesh1, mesh2, rays, origin)

        percentiles = np.linspace(0, 100, file_frames[i])
        percentile_intersections = calculate_percentile_intersections(intersections1, index_ray1, intersections2, index_ray2, percentiles)

        for p, intersections in zip(percentiles, percentile_intersections.values()):
            animation_frames.append((p, intersections))

    show_animation(mesh1, mesh2, origin, rays, animation_frames)  # add the missing 'rays' argument

if __name__ == "__main__":
    files = ["file1.stl", "file2.stl", "file3.stl", "file4.stl", "file5.stl", "file6.stl"]
    main(files)
