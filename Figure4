import numpy as np
import trimesh
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D
from scipy.spatial import Delaunay
import glob

def heron_area(a, b, c):
    s = (a + b + c) / 2.0
    return (s * (s - a) * (s - b) * (s - c))**0.5

def calculate_triangle_area(triangle):
    a = np.linalg.norm(triangle[1] - triangle[0])
    b = np.linalg.norm(triangle[2] - triangle[1])
    c = np.linalg.norm(triangle[0] - triangle[2])
    return heron_area(a, b, c)

def calculate_intersection_area(mesh, z_plane=10):
    intersections = []
    triangles = mesh.triangles
    
    for triangle in triangles:
        z_values = triangle[:, 2]
        if z_values.min() <= z_plane and z_values.max() >= z_plane:
            intersections.append(triangle)
    
    total_area = 0
    for triangle in intersections:
        total_area += calculate_triangle_area(triangle)
    
    return total_area


#　サイズ合わせの関数
def get_radius_at_z(mesh, z_plane=10.0):
    intersections = []
    triangles = mesh.triangles
    
    for triangle in triangles:
        z_values = triangle[:, 2]
        if z_values.min() <= z_plane and z_values.max() >= z_plane:
            intersections.append(triangle)

    # Flatten the list of triangles and then reshape to get all intersection points
    intersection_points = np.array(intersections).reshape(-1, 3)
    centroid = np.mean(intersection_points, axis=0)
    radii = np.linalg.norm(intersection_points - centroid, axis=1)
    max_radius = np.max(radii)
    
    return max_radius

def scale_mesh_to_target_area(mesh, target_radius, z_plane=10.0):
    current_radius = get_radius_at_z(mesh, z_plane)
    scale_factor = target_radius / current_radius
    mesh.vertices *= scale_factor
    new_radius = get_radius_at_z(mesh, z_plane)
    print(f"Before scaling: {current_radius}, After scaling: {new_radius}")
    return mesh


def alpha_shape(points, alpha):
    tri = Delaunay(points)
    triangles = points[tri.vertices]
    a = ((tri.points[tri.vertices][:, 0, :] - tri.points[tri.vertices][:, 1, :])**2).sum(axis=1)
    b = ((tri.points[tri.vertices][:, 1, :] - tri.points[tri.vertices][:, 2, :])**2).sum(axis=1)
    c = ((tri.points[tri.vertices][:, 2, :] - tri.points[tri.vertices][:, 0, :])**2).sum(axis=1)
    s = (a + b + c) / 2.0
    areas = (s * (s - a) * (s - b) * (s - c))**0.5
    circums = a * b * c / (4.0 * areas)
    filtered = triangles[circums < (1.0 / alpha)]
    edge1 = filtered[:, (0, 1)]
    edge2 = filtered[:, (1, 2)]
    edge3 = filtered[:, (2, 0)]
    edge_points = np.unique(np.concatenate((edge1, edge2, edge3)), axis=0)
    return edge_points


def save_mesh_to_stl(mesh, file_path):
    mesh.export(file_path, file_type='stl')


def load_mesh(file_path):
    return trimesh.load_mesh(file_path)

def adjust_z(mesh):
    min_z = np.min(mesh.vertices[:, 2])
    mesh.vertices[:, 2] -= min_z

def align_centroids_xy_only(mesh1, mesh2):
    centroid1 = mesh1.centroid
    centroid2 = mesh2.centroid
    offset = centroid1 - centroid2
    offset[2] = 0
    mesh2.vertices += offset

def generate_rays(centroid, num_rays=1000): # 放射線の数を増やせばメッシュの数も増える
    centroid[2] = 5  # 座標Z=5に重心を設定半球状に放射線を引く
    num_points = int(np.sqrt(num_rays))
    theta = np.linspace(0, np.pi / 2, num_points)  # ここの1を2にすると半球状に放射線を引く
    phi = np.linspace(0, 2 * np.pi, num_points)
    theta, phi = np.meshgrid(theta, phi)
    x = np.sin(theta) * np.cos(phi)
    y = np.sin(theta) * np.sin(phi)
    z = np.cos(theta)
    rays = np.vstack((x.flatten(), y.flatten(), z.flatten())).T
    return rays




def find_intersections(mesh1, mesh2, rays, origin):
    origin = np.tile(np.array(origin), (rays.shape[0], 1))
    rays = np.array(rays).reshape(-1, 3)

    intersections1, index_ray1, _ = mesh1.ray.intersects_location(origin, rays)
    intersections2, index_ray2, _ = mesh2.ray.intersects_location(origin, rays)

    return intersections1, index_ray1, intersections2, index_ray2



def visualize(mesh1, mesh2, origin, rays, intersections, average_intersections):
    fig = plt.figure()
    ax = fig.add_subplot(111, projection='3d')

    # Plot Mesh1 points (blue)
    ax.scatter(mesh1.vertices[:, 0], mesh1.vertices[:, 1], mesh1.vertices[:, 2], c='blue', alpha=0.3, s=5)

    # Plot Mesh2 points (cyan)
    ax.scatter(mesh2.vertices[:, 0], mesh2.vertices[:, 1], mesh2.vertices[:, 2], c='cyan', alpha=0.3, s=5)

    # Plot rays (green)
    ray_scale = 300  # Adjust this value to control the length of the rays
    for ray in rays:
        end_point = origin + ray * ray_scale
        ax.plot([origin[0], end_point[0]], [origin[1], end_point[1]], [origin[2], end_point[2]], c='g', linewidth=0.5)

    # Plot intersections (blue)
    if len(intersections) > 0:
        ax.scatter(intersections[:, 0], intersections[:, 1], intersections[:, 2], c='blue', s=3, marker='o')

    # Plot average intersections (red)
    if len(average_intersections) > 0:
        ax.scatter(average_intersections[:, 0], average_intersections[:, 1], average_intersections[:, 2], c='red', s=3, marker='o')

    ax.set_xlabel('X')
    ax.set_ylabel('Y')
    ax.set_zlabel('Z')

    plt.show()


def calculate_average_intersections(intersections, index_ray, valid_rays, meshes):
    average_intersections = np.zeros((len(valid_rays), 3))

    # Find the common ray indices that intersect all meshes
    common_indices = set(index_ray[0])
    for idx_ray in index_ray[1:]:
        common_indices.intersection_update(idx_ray)

    for i, idx in enumerate(common_indices):
        avg_intersection = np.zeros(3)
        count = 0
        for j in range(len(meshes)):
            where_result = np.where(index_ray[j] == idx)
            if where_result[0].size > 0:
                intersection_idx = where_result[0][0]
                avg_intersection += intersections[j][intersection_idx]
                count += 1
        if count == len(meshes):
            average_intersections[i] = avg_intersection / count

            # Print the intersection points and the calculated average point for ray ID = 250
            if idx == 250:
                print(f"Intersection points for ray ID {idx} in all files:")
                for k in range(len(meshes)):
                    print(f"File {k + 1}: {intersections[k][np.where(index_ray[k] == idx)[0][0]]}")
                print(f"Calculated average point (red point) for ray ID {idx}: {average_intersections[i]}")

    return average_intersections


def generate_alpha_mesh(average_intersections, alpha=1.0):
    if len(average_intersections) < 4:
        raise ValueError("At least 4 points are required to create a mesh")

    tri = Delaunay(average_intersections)
    new_faces = tri.simplices
    new_mesh = trimesh.Trimesh(vertices=average_intersections, faces=new_faces)

    return new_mesh

#点群データ保存の関数
def save_average_intersections_to_ply(points, file_path):
    with open(file_path, "w") as f:
        f.write("ply\n")
        f.write("format ascii 1.0\n")
        f.write(f"element vertex {len(points)}\n")
        f.write("property float x\n")
        f.write("property float y\n")
        f.write("property float z\n")
        f.write("end_header\n")

        for point in points:
            f.write(f"{point[0]} {point[1]} {point[2]}\n")


def main(stl_files):
    if len(stl_files) < 2:
        print("At least 2 STL files are needed.")
        return

    meshes = [load_mesh(file) for file in stl_files]

    for mesh in meshes:
        adjust_z(mesh)

    # 最初のメッシュのZ=10の平面での面積を計算
    initial_area = calculate_intersection_area(meshes[0], z_plane=10)
    print(f"File: {stl_files[0]}, Area (Z=10): {initial_area}")

    # すべてのメッシュを、指定された面積に拡大縮小
    for i, mesh in enumerate(meshes):
        target_radius = 5000  # or any desired value
        meshes[i] = scale_mesh_to_target_area(mesh, target_radius, z_plane=10)


    # 最初のメッシュに対してXY平面上の重心を合わせる
    for i in range(1, len(meshes)):
        align_centroids_xy_only(meshes[0], meshes[i])

    origin = np.array(meshes[0].centroid)
    origin[2] = 2

    rays = generate_rays(origin)
    rays /= np.linalg.norm(rays, axis=1)[:, np.newaxis]  # Normalize rays to make them unit vectors

    intersections = []
    index_rays = []

    for mesh in meshes:
        inter, index_ray, _, _ = find_intersections(mesh, mesh, rays, origin)
        intersections.append(inter)
        index_rays.append(index_ray)

    # Calculate the average intersections for rays that intersect all meshes
    valid_rays = np.intersect1d(index_rays[0], index_rays[1])
    for i in range(2, len(index_rays)):
        valid_rays = np.intersect1d(valid_rays, index_rays[i])

    average_intersections = calculate_average_intersections(intersections, index_rays, valid_rays, meshes)



    for i, valid_ray_idx in enumerate(valid_rays):
        avg_intersection = np.zeros(3)
        for j in range(len(meshes)):
            intersection_idx = np.where(index_rays[j] == valid_ray_idx)[0][0]
            avg_intersection += intersections[j][intersection_idx]
        average_intersections[i] = avg_intersection / len(meshes)




    # Visualize the first and the last mesh with the average intersections
    visualize(meshes[0], meshes[-1], origin, rays, intersections[0], average_intersections)


    alpha_mesh = generate_alpha_mesh(average_intersections)

    output_file_path = "output.stl"
    save_mesh_to_stl(alpha_mesh, output_file_path)
    print(f"Mesh saved to: {output_file_path}")
    
    output_average_intersections_path = "average_intersections.ply"
    save_average_intersections_to_ply(average_intersections, output_average_intersections_path)
    print(f"Average intersections saved to: {output_average_intersections_path}")


if __name__ == "__main__":
    file_pattern = "iwa*.stl"
    stl_files = sorted(glob.glob(file_pattern))
    main(stl_files)
