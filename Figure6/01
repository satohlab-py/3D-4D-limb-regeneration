import os
import trimesh
import glob
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.collections as mcoll
import imageio  

# カレントディレクトリの *.stl ファイルを取得
stl_files = glob.glob('*.stl')

# For saving the images to stack later
saved_images = []

# 3D TIFFファイルを読み込む
img = imageio.volread('Composite.tif')

# Z方向のスタック数（画像枚数）を取得
z_stack_number = 1 + img.shape[0]

for file_index, file_name in enumerate(stl_files):
    # メッシュの読み込み
    mesh = trimesh.load_mesh(file_name)

    # メッシュが有効であることを確認
    if mesh.is_empty:
        print(f"Invalid or empty mesh in file {file_name}!")
        continue

    # メッシュの最大と最小Z値を取得
    z_min, z_max = mesh.bounds[:, 2]

    # 面の法線
    plane_normal = (0, 0, 1)

    # z_minからz_maxまでの範囲を、z_stack_numberに分割
    z_values = np.linspace(z_min, z_max, z_stack_number)
    print(z_stack_number)

    # 重心を格納するリスト
    centroids = []

    for z_index, z in enumerate(z_values):  # Added z_index here
        # 平面の原点を定義
        plane_origin = (0, 0, z)

        # 平面でメッシュを切断し、その断面を取得
        slice = mesh.section(plane_origin=plane_origin, plane_normal=plane_normal)

        # sliceがNoneか確認
        if slice is None:
            continue

        # 2Dポリラインに変換
        slice_2D, _ = slice.to_planar()

        lines = []  # Moved this line inside the loop

        # 各ポリゴンの座標と重心を格納
        for polygon in slice_2D.polygons_closed:
            lines.append(np.array(polygon.exterior.coords))
            centroids.append(np.array(polygon.centroid.coords[0]))

        # ラインコレクションを作成
        lc = mcoll.LineCollection(lines, colors=plt.cm.viridis(np.linspace(0, 1, len(lines))))

        fig, ax = plt.subplots()
        ax.add_collection(lc)

        # Set fixed scale for X and Y axes
        ax.set_xlim([-5000, 5000])  # Added this line
        ax.set_ylim([-4000, 4000])  # Added this line

        # わくと目盛りの除去　必要なら、下記5行をコメントアウト　Remove ticks and labels
        ax.set_xticks([])  # Remove x-ticks
        ax.set_yticks([])  # Remove y-ticks
        ax.set_xticklabels([])  # Remove x-tick labels
        ax.set_yticklabels([])  # Remove y-tick labels
        ax.axis('off')  # This will remove the box around the plot as well




        # 一番初めと最後の重心が存在する場合、それぞれを表示
        #if centroids:
        #    ax.plot(*centroids[0], 'bo', markersize=4)
        #    ax.plot(*centroids[-1], 'yo', markersize=4)

        ax.autoscale_view()

        # グラフを表示
        output_filename = f"slice_{file_index}_{z_index}.png"  # Updated filename
        saved_images.append(output_filename)  # Append the filename to the list
        plt.savefig(output_filename)
        plt.close(fig)  # メモリの節約のためプロットをクローズ

# Load the saved images and save them as a 3D TIFF
saved_images = sorted(saved_images, key=lambda x: int(x.split('_')[2].split('.')[0]))  # Sorted the filenames
imgs = [imageio.imread(f) for f in saved_images]
imageio.mimsave('stacked.tiff', imgs, format='TIFF')  # Save the images as a 3D TIFF

# Remove temporary images
for img_file in saved_images:
    try:
        os.remove(img_file)
        print(f"Successfully deleted temporary file: {img_file}")
    except Exception as e:
        print(f"Could not delete temporary file {img_file}. Reason: {e}")
